{
  "name": "github-actions-policy-enforcement-app",
  "version": "1.0.0",
  "private": true,
  "description": "Probot app that enforces a production incident freeze by cancelling workflow runs.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "probot run ./dist/index.js",
    "dev": "npm run build && npm start",
    "check": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --runInBand",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --watch"
  },
  "dependencies": {
    "probot": "^14.0.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "smee-client": "^5.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
